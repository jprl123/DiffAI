# diffAI — variáveis de ambiente (servidor de licenças + referência para Vercel)
# Copie para .env local. NUNCA commite .env com segredos reais.

# === Railway (API de licenças) ===
# PORT=                    # Railway preenche automaticamente
# COMPAREDOCS_DATA_DIR=/data
# COMPAREDOCS_LICENSE_DB=/data/licenses.db
# COMPAREDOCS_SIGNING_KEY=/data/signing_key.pem

# Cole a chave privada PEM inteira (Secret no Railway) — alternativa ao volume:
# COMPAREDOCS_SIGNING_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...

MAIL_BACKEND=console
# MAIL_BACKEND=resend
# RESEND_API_KEY=re_...
# MAIL_FROM=diffAI <noreply@diffai.app>
# MAIL_TO_OVERRIDE=seu@email.com

# URLs após checkout Stripe (use a URL da sua landing na Vercel)
SUCCESS_URL=https://SUA-LANDING.vercel.app/conta?checkout=ok
CANCEL_URL=https://SUA-LANDING.vercel.app/#planos

# CORS — origens exatas da landing (sem barra no final), separadas por vírgula
PORTAL_ALLOWED_ORIGINS=https://comparedocs-landing.vercel.app

# === Vercel (landing — prefixo NEXT_PUBLIC_) ===
# NEXT_PUBLIC_LICENSE_API=https://SUA-API.up.railway.app
# NEXT_PUBLIC_DOWNLOAD_URL_MAC=
# NEXT_PUBLIC_DOWNLOAD_URL_WINDOWS=
# NEXT_PUBLIC_SALES_EMAIL=vendas@diffai.app

# === App desktop (build) ===
# COMPAREDOCS_LICENSE_SERVER=https://SUA-API.up.railway.app

# === Pareamento por IA (OpenRouter) — opcional ===
# Casa base<->revisado por conteúdo quando nome/similaridade/conteúdo não
# resolvem. Opt-in na UI; só ativa com a chave preenchida.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# COMPAREDOCS_AI_MODEL=deepseek/deepseek-v4-flash
# COMPAREDOCS_AI_PAIRING=0   # desliga mesmo com chave presente
