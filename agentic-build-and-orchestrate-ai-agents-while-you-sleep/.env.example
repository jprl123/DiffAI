# === Envs públicas da landing (Vercel → Settings → Environment Variables) ===
# Depois de salvar, faça Redeploy. NEXT_PUBLIC_* só entram no build.

# URL HTTPS do servidor de licenças (Railway/Render/Azure — NÃO a Vercel)
# Exemplo: https://diffai-licensing.up.railway.app
NEXT_PUBLIC_LICENSE_API=http://127.0.0.1:8390

# Instaladores (deixe vazio até o arquivo existir no storage/GitHub Releases)
NEXT_PUBLIC_DOWNLOAD_URL_MAC=https://downloads.diffai.app/diffAI-mac.dmg
NEXT_PUBLIC_DOWNLOAD_URL_WINDOWS=https://downloads.diffai.app/diffAI-windows.exe

# Opcional
NEXT_PUBLIC_SALES_EMAIL=vendas@diffai.app
